# Configuration principale LOGPIPE-RELAY
# Copiez ce fichier vers .env et ajustez ROOT_DIR si nécessaire.
#
# Seul ROOT_DIR est requis. Tous les sous-dossiers sont créés automatiquement :
#
#   ROOT_DIR/
#   ├── inputs/     ← fichiers .log extraits (destination pour l'ingestor)
#   ├── data/       ← pipeline interne (incoming, extracted, processed, error)
#   ├── state/      ← suivi d'état / idempotence
#   ├── logs/       ← journaux d'exécution
#   └── tmp/        ← fichiers temporaires

# Linux
ROOT_DIR=/opt/logpipe-relay

# Windows (exemple)
# ROOT_DIR=D:\logpipe-relay

# Configuration retry
MAX_RETRY_COPY=3
MAX_RETRY_EXTRACT=3
RETRY_DELAY_BASE=60
RETRY_DELAY_MAX=3600
RETRY_BACKOFF_MULTIPLIER=2

# Configuration rsync
RSYNC_TIMEOUT=300
RSYNC_OPTIONS=-avz --partial

# Configuration extraction
GZIP_VALIDATE=True
EXTRACT_DELETE_SOURCE=False

# Configuration logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_ROTATION=True
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
