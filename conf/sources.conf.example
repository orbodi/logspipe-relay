# Configuration des serveurs sources
# Chaque serveur : name, host, user, remote_path, enabled
# Authentification user/password :
#   - "password" dans ce fichier (sources.conf est gitignoré), ou
#   - SSH_PASSWORD / SSH_PASSWORD_<NAME> dans conf/.env

{
  "servers": [
    {
      "name": "brs1",
      "host": "192.168.1.10",
      "user": "loguser",
      "password": "votreMotDePasse",
      "remote_path": "/var/log/abis/*.log.gz",
      "enabled": true
    },
    {
      "name": "brs2",
      "host": "192.168.1.11",
      "user": "loguser",
      "remote_path": "/var/log/abis/*.log.gz",
      "enabled": true
    }
  ]
}

